# FocusTracker Konfiguration (alle Werte optional)

# Wo die SQLite-DB und Backups liegen sollen.
# Default: ~/.focustracker
# FOCUSTRACKER_DATA_DIR=/path/to/data

# Port fuer Web-Dashboard (default: 5050).
# Bei mehreren Servern auf einer Maschine pro Account anderen Port setzen.
# FOCUSTRACKER_PORT=5050

# Name eines macOS-Shortcuts, der "Do Not Disturb" togglet.
# Wird beim Start/Stop einer Session ausgeführt.
# Wenn nicht gesetzt: DND-Funktion ist deaktiviert.
# FOCUSTRACKER_DND_SHORTCUT=Nicht Stoeren
